{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-dotnet.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-secrets-in-config.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-dotnet.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-stop-reminder.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-vulnerable-packages.sh",
        "timeoutSec": 60
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-secrets-in-config.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-reminder.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-progress.sh",
        "timeoutSec": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-ops.sh",
        "timeoutSec": 10
      }
    ],
    "PostToolUseFailure": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dotnet-failure-hints.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-critic.sh",
        "timeoutSec": 15
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-iron-laws.sh",
        "timeoutSec": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-dirs.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-scratchpad.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-resume.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-branch-freshness.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "echo '.NET AI Toolkit loaded \u2014 describe your task and I'\\''ll suggest the right workflow'"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-rules.sh",
        "timeoutSec": 15
      }
    ],
    "PostCompact": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/postcompact-verify.sh",
        "timeoutSec": 15
      }
    ],
    "StopFailure": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-failure-log.sh",
        "timeoutSec": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "bash": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-pending-plans.sh",
        "timeoutSec": 15
      }
    ]
  }
}
